// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================
// ENUMS
// ========================

enum Role {
  ADMIN
  SELLER
}

enum ProductCondition {
  NUEVO
  USADO
}

enum ProductSaleUnit {
  UNIDAD
  METRO
}

enum ProductStatus {
  ACTIVO
  INACTIVO
  DESCONTINUADO
}

enum SaleLineType {
  PRODUCTO
  REMACHADO
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  QR
  TARJETA
}

enum SaleType {
  CONTADO
  CREDITO
}

enum DebtStatus {
  PENDIENTE
  PARCIAL
  PAGADA
  VENCIDA
}

enum PurchaseStatus {
  BORRADOR
  RECIBIDA
  ANULADA
}

enum StockMovementType {
  VENTA
  COMPRA
  AJUSTE
  TRANSFERENCIA_SALIDA
  TRANSFERENCIA_ENTRADA
}

enum RemachadoTrabajoTipo {
  JUEGO
  MEDIO_JUEGO
}

enum RemachadoMovimientoTipo {
  INGRESO
  AJUSTE
  TRABAJO
}

// ========================
// MODELOS
// ========================

model Sucursal {
  id        String     @id @default(uuid())
  nombre    String
  whatsapp  String?
  usuarios  Usuario[]
  productos Producto[]
  productoStocks ProductoStockSucursal[]
  eliminacionesProducto ProductoEliminacionHistorial[]
  ventas    Venta[]
  compras   Compra[]
  cierresCaja CierreCaja[]
  gastosCaja GastoCaja[]
  remachadoTrabajos RemachadoTrabajo[]
  createdAt DateTime   @default(now())
}

model Categoria {
  id        String     @id @default(uuid())
  nombre    String @unique
  productos Producto[]
  createdAt DateTime   @default(now())
}

model Usuario {
  id         String   @id @default(uuid())
  nombre     String
  email      String   @unique
  password   String
  role       Role     @default(SELLER)
  activo     Boolean  @default(true)
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  ventas     Venta[]
  movimientos MovimientoStock[]
  eliminacionesProducto ProductoEliminacionHistorial[]
  cierresCaja CierreCaja[]
  gastosCaja GastoCaja[]
  remachadoTrabajos RemachadoTrabajo[]
  remachadoMovimientos RemachadoMovimiento[]
  createdAt  DateTime @default(now())
}

model Proveedor {
  id              String   @id @default(uuid())
  nombre          String
  contacto        String?
  telefono        String?
  email           String?
  pais            String?
  direccion       String?
  notas           String?
  deudaPendiente  Float    @default(0)
  activo          Boolean  @default(true)
  compras         Compra[]
  productos       Producto[]
  createdAt       DateTime @default(now())
}

model Cliente {
  id        String         @id @default(uuid())
  nombre    String
  telefono  String?
  email     String?        @unique
  password  String?
  empresa   String?
  ciudad    String?
  nit       String?
  direccion String?
  notas     String?
  activo    Boolean        @default(true)
  ventas    Venta[]
  cuentas   CuentaCobrar[]
  createdAt DateTime       @default(now())
}

model Producto {
  id           String           @id @default(uuid())
  codigo       String
  codigoRepuesto String?
  descripcion  String
  marca        String
  condicion    ProductCondition @default(NUEVO)
  unidadVenta  ProductSaleUnit  @default(UNIDAD)
  stock        Float            @default(0)
  stockMinimo  Float            @default(5)
  ubicacion    String?
  activo       Boolean          @default(true)
  estado       ProductStatus    @default(ACTIVO)
  precioCompra Float
  precioVenta  Float
  imagen       String?
  proveedorId  String?
  proveedor    Proveedor?       @relation(fields: [proveedorId], references: [id])
  categoriaId  String
  categoria    Categoria        @relation(fields: [categoriaId], references: [id])
  sucursalId   String
  sucursal     Sucursal         @relation(fields: [sucursalId], references: [id])
  stockSucursales ProductoStockSucursal[]
  imagenes     ProductoImagen[]
  detalles     DetalleVenta[]
  detallesCompra DetalleCompra[]
  movimientos  MovimientoStock[]
  eliminacionesHistorial ProductoEliminacionHistorial[]
  alertas      AlertaStock[]
  transferenciasOrigen TransferenciaStock[] @relation("ProductoTransferenciaOrigen")
  transferenciasDestino TransferenciaStock[] @relation("ProductoTransferenciaDestino")
  remachadoResorteTrabajos RemachadoTrabajo[] @relation("RemachadoResorteProducto")
  remachadoGomaTrabajos    RemachadoTrabajo[] @relation("RemachadoGomaProducto")
  remachadoSeguroTrabajos  RemachadoTrabajo[] @relation("RemachadoSeguroProducto")
  createdAt    DateTime         @default(now())

  @@unique([codigo, sucursalId])
}

model ProductoEliminacionHistorial {
  id             String        @id @default(uuid())
  productoId     String
  producto       Producto      @relation(fields: [productoId], references: [id])
  sucursalId     String?
  sucursal       Sucursal?     @relation(fields: [sucursalId], references: [id])
  usuarioId      String?
  usuario        Usuario?      @relation(fields: [usuarioId], references: [id])
  motivo         String
  stockAnterior  Float         @default(0)
  estadoAnterior ProductStatus @default(ACTIVO)
  createdAt      DateTime      @default(now())

  @@index([productoId])
  @@index([sucursalId])
  @@index([createdAt])
}

model ProductoStockSucursal {
  id         String   @id @default(uuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sucursalId String
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  stock      Float    @default(0)
  activo     Boolean  @default(true)
  estado     ProductStatus @default(ACTIVO)
  createdAt  DateTime @default(now())

  @@unique([productoId, sucursalId])
  @@index([sucursalId])
}

model ProductoImagen {
  id         String   @id @default(uuid())
  url        String
  publicId   String?
  orden      Int      @default(0)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([productoId])
}

model Venta {
  id         String         @id @default(uuid())
  subtotal   Float
  descuento  Float          @default(0.0)
  total      Float
  metodoPago PaymentMethod
  tipoVenta  SaleType       @default(CONTADO)
  usuarioId  String
  usuario    Usuario        @relation(fields: [usuarioId], references: [id])
  sucursalId String
  sucursal   Sucursal       @relation(fields: [sucursalId], references: [id])
  clienteId  String?
  cliente    Cliente?       @relation(fields: [clienteId], references: [id])
  detalles   DetalleVenta[]
  remachadoTrabajos RemachadoTrabajo[]
  cuenta     CuentaCobrar?
  createdAt  DateTime       @default(now())
}

model DetalleVenta {
  id             String   @id @default(uuid())
  tipoLinea      SaleLineType @default(PRODUCTO)
  descripcion    String?
  unidadVenta    String?
  cantidad       Float
  precioUnitario Float
  subtotal       Float
  ventaId        String
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId     String?
  producto       Producto? @relation(fields: [productoId], references: [id])
  remachadoTrabajoId String?
  remachadoTrabajo   RemachadoTrabajo? @relation(fields: [remachadoTrabajoId], references: [id])
  createdAt      DateTime @default(now())
}

model Compra {
  id          String          @id @default(uuid())
  proveedorId String
  proveedor   Proveedor       @relation(fields: [proveedorId], references: [id])
  sucursalId  String
  sucursal    Sucursal        @relation(fields: [sucursalId], references: [id])
  usuarioId   String
  subtotal    Float
  total       Float
  estado      PurchaseStatus  @default(RECIBIDA)
  notas       String?
  detalles    DetalleCompra[]
  createdAt   DateTime        @default(now())
}

model DetalleCompra {
  id             String   @id @default(uuid())
  compraId       String
  compra         Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  productoId     String
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Float
  precioUnitario Float
  subtotal       Float
  createdAt      DateTime @default(now())
}

model MovimientoStock {
  id             String            @id @default(uuid())
  tipoMovimiento StockMovementType
  productoId     String
  producto       Producto          @relation(fields: [productoId], references: [id])
  sucursalId      String
  stockAnterior   Float
  stockNuevo      Float
  cantidad        Float
  usuarioId       String?
  usuario         Usuario?         @relation(fields: [usuarioId], references: [id])
  referenciaId    String?
  referenciaTipo  String?
  notas           String?
  createdAt       DateTime         @default(now())
}

model TransferenciaStock {
  id                String   @id @default(uuid())
  productoOrigenId  String
  productoOrigen    Producto @relation("ProductoTransferenciaOrigen", fields: [productoOrigenId], references: [id])
  productoDestinoId String
  productoDestino   Producto @relation("ProductoTransferenciaDestino", fields: [productoDestinoId], references: [id])
  sucursalOrigenId  String
  sucursalDestinoId String
  cantidad          Float
  usuarioId         String
  notas             String?
  createdAt         DateTime @default(now())
}

model AlertaStock {
  id        String   @id @default(uuid())
  productoId String
  producto  Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  tipo      String
  mensaje   String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CuentaCobrar {
  id               String       @id @default(uuid())
  clienteId        String
  cliente          Cliente      @relation(fields: [clienteId], references: [id])
  ventaId          String       @unique
  venta            Venta        @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  sucursalId       String
  montoTotal       Float
  montoPagado      Float        @default(0)
  saldo            Float
  fechaVencimiento DateTime?
  estado           DebtStatus   @default(PENDIENTE)
  notas            String?
  pagos            PagoCredito[]
  createdAt        DateTime     @default(now())
}

model PagoCredito {
  id          String        @id @default(uuid())
  cuentaId    String
  cuenta      CuentaCobrar  @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  monto       Float
  metodoPago  PaymentMethod
  usuarioId   String
  notas       String?
  createdAt   DateTime      @default(now())
}

model CierreCaja {
  id                String   @id @default(uuid())
  fecha             DateTime
  usuarioId         String
  usuario           Usuario  @relation(fields: [usuarioId], references: [id])
  sucursalId        String
  sucursal          Sucursal @relation(fields: [sucursalId], references: [id])
  cantidadVentas    Int
  totalVentas       Float
  totalEfectivo     Float
  totalTransferencia Float
  totalQr           Float
  totalTarjeta      Float
  totalCredito      Float
  gastoEfectivo     Float    @default(0)
  gastoQr           Float    @default(0)
  totalGastos       Float    @default(0)
  netoEfectivo      Float    @default(0)
  netoQr            Float    @default(0)
  montoDeclarado    Float
  diferencia        Float
  notas             String?
  createdAt         DateTime @default(now())

  @@unique([fecha, usuarioId, sucursalId])
}

model GastoCaja {
  id         String        @id @default(uuid())
  motivo     String
  monto      Float
  metodoPago PaymentMethod
  notas      String?
  usuarioId  String
  usuario    Usuario       @relation(fields: [usuarioId], references: [id])
  sucursalId String
  sucursal   Sucursal      @relation(fields: [sucursalId], references: [id])
  createdAt  DateTime      @default(now())

  @@index([usuarioId, sucursalId, createdAt])
  @@index([sucursalId, createdAt])
}

model RemachadoMedida {
  id                 String                @id @default(uuid())
  medida             String                @unique
  descripcion        String?
  stockJuegos        Float                 @default(0)
  stockMinimoJuegos  Float                 @default(1)
  precioJuego        Float
  precioMedioJuego   Float
  remachesPorJuego   Int                   @default(8)
  remachesPorMedioJuego Int                @default(4)
  activo             Boolean               @default(true)
  trabajos           RemachadoTrabajo[]
  movimientos        RemachadoMovimiento[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model RemachadoRemache {
  id          String                @id @default(uuid())
  codigo      String                @unique
  nombre      String
  medida      String?
  stock       Int                   @default(0)
  stockMinimo Int                   @default(20)
  activo      Boolean               @default(true)
  trabajos    RemachadoTrabajo[]
  movimientos RemachadoMovimiento[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model RemachadoTrabajo {
  id               String               @id @default(uuid())
  medidaId         String
  medida           RemachadoMedida      @relation(fields: [medidaId], references: [id])
  remacheId        String?
  remache          RemachadoRemache?    @relation(fields: [remacheId], references: [id])
  usuarioId        String
  usuario          Usuario              @relation(fields: [usuarioId], references: [id])
  sucursalId       String
  sucursal         Sucursal             @relation(fields: [sucursalId], references: [id])
  ventaId          String?
  venta            Venta?               @relation(fields: [ventaId], references: [id])
  tipoTrabajo      RemachadoTrabajoTipo
  cantidadJuegos   Float
  cantidadBalatas  Int
  cantidadRemaches Int
  resorteProductoId String?
  resorteProducto   Producto?            @relation("RemachadoResorteProducto", fields: [resorteProductoId], references: [id])
  cantidadResortes  Int                  @default(0)
  gomaProductoId    String?
  gomaProducto      Producto?            @relation("RemachadoGomaProducto", fields: [gomaProductoId], references: [id])
  cantidadGomas     Int                  @default(0)
  seguroProductoId  String?
  seguroProducto    Producto?            @relation("RemachadoSeguroProducto", fields: [seguroProductoId], references: [id])
  cantidadSeguros   Int                  @default(0)
  precioUnitario   Float
  total            Float
  notas            String?
  detalleVenta     DetalleVenta[]
  movimientos      RemachadoMovimiento[]
  createdAt        DateTime             @default(now())

  @@index([medidaId])
  @@index([remacheId])
  @@index([ventaId])
  @@index([resorteProductoId])
  @@index([gomaProductoId])
  @@index([seguroProductoId])
  @@index([createdAt])
}

model RemachadoMovimiento {
  id              String                  @id @default(uuid())
  tipo            RemachadoMovimientoTipo
  medidaId        String?
  medida          RemachadoMedida?        @relation(fields: [medidaId], references: [id])
  remacheId       String?
  remache         RemachadoRemache?       @relation(fields: [remacheId], references: [id])
  trabajoId       String?
  trabajo         RemachadoTrabajo?       @relation(fields: [trabajoId], references: [id])
  usuarioId       String?
  usuario         Usuario?                @relation(fields: [usuarioId], references: [id])
  stockAnterior   Float
  stockNuevo      Float
  cantidad        Float
  notas           String?
  createdAt       DateTime                @default(now())

  @@index([medidaId])
  @@index([remacheId])
  @@index([trabajoId])
  @@index([createdAt])
}
